# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
build/
dist/
*.egg-info/
.eggs/

# Environment
.env
*.env.local

# Streamlit secrets (nunca commitar — contém chaves de API)
.streamlit/secrets.toml

# Data — PDFs não versionados (baixar manualmente, ver README)
data/raw/*
!data/.gitkeep
!data/raw/.gitkeep
!data/raw/educacao/
!data/raw/educacao/.gitkeep

# Índice ChromaDB — VERSIONADO (gerado por python -m ingest.pipeline)
# Todos os arquivos individuais < 100 MB → compatível com GitHub sem LFS
!data/processed/
!data/processed/.gitkeep
!data/processed/chroma/
!data/processed/chroma/**

# ChromaDB
chroma_db/

# Backups temporários de desenvolvimento
.README_full.md

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Avaliação — resultados gerados
eval/results/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Docker
.docker/
