# ============================================================
# EduRAG — Variáveis de Ambiente (Template)
# Copie para .env e preencha com seus valores reais.
# NUNCA commite o .env no repositório.
# ============================================================

# --- LLM Principal: Ollama (preferência OSS local) ---
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Outros modelos testados: qwen2.5, mistral, gemma2

# --- LLM Fallback: OpenAI (se USE_OLLAMA=false) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings: HuggingFace OSS (sem custo de API) ---
EMBEDDING_MODEL=BAAI/bge-m3
# Alternativa mais leve: BAAI/bge-small-en-v1.5

# --- VectorStore ---
CHROMA_PERSIST_DIR=./data/processed/chroma

# --- MCP Server ---
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_LOG_LEVEL=INFO

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Self-check ---
# Limiar mínimo de fidelidade (0.0–1.0); abaixo → re-busca ou recusa
SELF_CHECK_THRESHOLD=0.7

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
