# ============================================================
# EduRAG — Variáveis de Ambiente (Template)
# Copie para .env e preencha com seus valores reais.
# NUNCA commite o .env no repositório.
# ============================================================

# --- Provedor do LLM ---
# Opções: "ollama" (local) | "replicate" (nuvem) | "openai" (nuvem)
LLM_PROVIDER=ollama

# --- LLM: Ollama (desenvolvimento local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Outros modelos testados: qwen2.5, mistral, gemma2

# --- LLM: Replicate (deploy na nuvem — use seus créditos) ---
# Obtenha o token em: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...
# Modelos recomendados (bom português):
#   meta/meta-llama-3-8b-instruct      → rápido, barato (~$0.05/1M tokens)
#   meta/meta-llama-3-70b-instruct     → mais preciso, mais caro
#   mistralai/mistral-7b-instruct-v0.2 → alternativa leve
REPLICATE_MODEL=meta/meta-llama-3-8b-instruct

# --- LLM: OpenAI (fallback opcional) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings ---
# Opções: "huggingface" (local, zero custo de API) | "openai" (via API)
EMBEDDING_PROVIDER=huggingface
# Para desenvolvimento local (multilíngue, alta qualidade):
EMBEDDING_MODEL=BAAI/bge-m3
# ⚠ Para Streamlit Cloud (limite ~1 GB RAM), use o modelo leve:
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Se EMBEDDING_PROVIDER=openai, o modelo text-embedding-3-small é usado automaticamente

# --- VectorStore ChromaDB ---
# Opções: "local" (desenvolvimento) | "cloud" (deploy Streamlit Cloud)
CHROMA_MODE=local
CHROMA_PERSIST_DIR=./data/processed/chroma

# ChromaDB Cloud (quando CHROMA_MODE=cloud)
# Crie conta gratuita em https://trychroma.com (até 1M vetores grátis)
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=edurag

# --- MCP Server ---
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_LOG_LEVEL=INFO

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Self-check ---
# Limiar mínimo de fidelidade (0.0–1.0); abaixo → re-busca ou recusa
SELF_CHECK_THRESHOLD=0.7

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
