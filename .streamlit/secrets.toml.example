# ============================================================
# EduRAG — Streamlit Cloud Secrets (Template)
#
# Como usar:
#   1. No painel do Streamlit Cloud → seu app → Settings → Secrets
#   2. Cole o conteúdo abaixo preenchido com seus valores reais
#   3. Nunca commite o arquivo secrets.toml (já está no .gitignore)
#
# Para testar localmente: copie para .streamlit/secrets.toml
# ============================================================

# --- Provedor do LLM ---
# Use "replicate" para usar seus créditos do Replicate
LLM_PROVIDER = "replicate"

# --- Replicate ---
# Token em: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN = "r8_SeuTokenAqui"
REPLICATE_MODEL = "openai/gpt-4o-mini"

# --- Embeddings ---
# No Streamlit Cloud, use o modelo leve (cabe no limite de RAM)
EMBEDDING_PROVIDER = "huggingface"
EMBEDDING_MODEL = "BAAI/bge-small-en-v1.5"

# --- ChromaDB — índice local commitado no repositório ---
# O índice fica em data/processed/chroma/ (já no git)
# O Streamlit Cloud lê direto do repo — sem necessidade de ChromaDB Cloud
CHROMA_MODE = "local"
CHROMA_PERSIST_DIR = "./data/processed/chroma"

# --- Self-check ---
SELF_CHECK_THRESHOLD = "0.7"

# --- Logging ---
LOG_LEVEL = "INFO"
LOG_FORMAT = "json"
